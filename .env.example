# Runway stack configuration. Copy to .env and fill in.
#
# install.sh writes this file for you, but you can also create it
# manually before running `docker compose up -d --build`.

# Domain where the Runway dashboard will be reachable.
# Must already point (DNS A record) to this server.
DASHBOARD_DOMAIN=runway.example.com

# Email address used to register with Let's Encrypt. Receives expiry
# notifications for certificates issued for your apps.
ACME_EMAIL=you@example.com
